    affiliation: "Insper"
version: "1.0.0"
date-released: "2026-04-18"
license: CC-BY-4.0
repository-code: "https://github.com/vr-rodrigues/health-did-replication"
keywords:
  - difference-in-differences
  - two-way fixed effects
  - Callaway-Sant'Anna
  - health economics
  - replication
  - causal inference
references:
